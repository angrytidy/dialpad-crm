# Less Annoying CRM API (from Programmer API settings)
CRM_API_KEY=your_crm_api_key
# Required for CRM_API_VERSION=v1 (legacy); optional for v2
CRM_USER_CODE=your_user_code

# v2 = POST /v2/ with Authorization: CRM_API_KEY. v1 = POST root with UserCode+APIToken in body.
# CRM_API_VERSION=v2

# LAC User ID to assign new contacts to (required for creating contacts; get from Users in LAC)
CRM_ASSIGNED_TO=123456

# Optional: webhook server port (default 3000)
PORT=3000

# --- Dialpad API (for registering webhook via API; optional) ---
# Public URL of this server (e.g. https://your-domain.com or https://xxxx.ngrok.io)
# PUBLIC_WEBHOOK_URL=https://your-server.com
# Dialpad API key (Admin → My Company → Authentication → API Keys; include recordings_export etc.)
# DIALPAD_API_KEY=your_dialpad_api_key
# Optional: secret for webhook payload signing (HS256 JWT). If set, Dialpad sends JWT and server verifies it.
# DIALPAD_WEBHOOK_SECRET=your-optional-secret
